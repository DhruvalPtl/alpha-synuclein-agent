# ── Serialised model artefacts (large checkpoints only) ──────────────────────
*.pt
*.pth
*.ckpt
# keep data/processed/*.pkl tracked (small sklearn objects)
data/splits/*.pkl
data/splits/*.sha256
experiments/*/artifacts/*.pkl
experiments/*/artifacts/*.pt
experiments/*/artifacts/*.pth

# ── Logs (never commit raw logs) ──────────────────────────────────────────────
master_log/master_terminal.log

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Environment files (actual values, not the template) ──────────────────────
.env

# ── Jupyter checkpoints ───────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Experiment binary artefacts ───────────────────────────────────────────────
experiments/*/artifacts/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
env/
