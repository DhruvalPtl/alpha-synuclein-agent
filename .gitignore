# ── Serialised model artefacts (large binary weights — never track) ───────────
*.pt
*.pth
*.ckpt

# ── Experiment artifacts (model weights, too large for git) ───────────────────
# Per-experiment SOURCE files (model.py / train.py / eval.py / results.json /
# config.yaml) ARE tracked — unique folder names prevent cross-machine conflicts.
# Only the large binary artifacts directory is ignored.
experiments/*/artifacts/
# Also ignore raw split pkl arrays (re-generated from CSV in seconds)
data/splits/*.pkl
data/splits/*.sha256
# Ignore processed pkl artifacts only if not force-added
# (scaler.pkl, selector.pkl, class_weights.pkl are force-added via git add -f)

# ── Runtime-only state (NEVER let git pull overwrite live run state) ──────────
# leaderboard.json is rebuilt from experiments/*/results.json via
# rebuild_leaderboard.py — it is NOT a source of truth, just a cache.
# Keeping it untracked prevents merge conflicts during live agent runs.
master_log/leaderboard.json
master_log/orchestrator_state.json
master_log/master_terminal.log

# ── Sessions folder: partial tracking ─────────────────────────────────────────
# session_summary.json  — TRACKED  (small, useful history across machines)
# session_log.log       — IGNORED  (too large, per-machine run noise)
# heartbeat.json        — IGNORED  (machine-local, overwrites every 10 s)
sessions/*/session_log.log
sessions/*/heartbeat.json

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Environment files (actual values — template is in repo) ──────────────────
.env

# ── Jupyter checkpoints ───────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
