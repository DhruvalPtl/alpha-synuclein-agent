# ── Serialised model artefacts (large checkpoints only) ──────────────────────
*.pt
*.pth
*.ckpt
# keep data/processed/*.pkl tracked (small sklearn objects)
data/splits/*.pkl
data/splits/*.sha256
experiments/*/artifacts/*.pkl
experiments/*/artifacts/*.pt
experiments/*/artifacts/*.pth

# ── Runtime state (never overwrite with git pull) ────────────────────────────
# These are generated at runtime — git pull must NEVER overwrite them.
# leaderboard.json accumulates experiments on cloud: if tracked, git pull
# will MERGE CONFLICT mid-run. Untracked = cloud state always safe.
master_log/leaderboard.json
master_log/orchestrator_state.json
master_log/master_terminal.log
experiments/*/model.py
experiments/*/train.py
experiments/*/eval.py
experiments/*/results.json

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Environment files (actual values, not the template) ──────────────────────
.env

# ── Jupyter checkpoints ───────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Experiment binary artefacts ───────────────────────────────────────────────
experiments/*/artifacts/

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
env/
